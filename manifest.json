{
  "manifest_version": 3,
  "name": "SimpRead",
  "version": "1.2",
  "permissions": ["sidePanel", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ]
}
